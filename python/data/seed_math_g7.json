              "content": {
                "stem": "若|x|=5，则x=______。"
              },
              "answer": {"value": "5或-5"},
              "analysis": {
                "text": "绝对值的定义：|a|=a（a≥0）或|a|=-a（a<0）。所以|x|=5的解为x=5或x=-5。",
                "key_point": "绝对值方程的解法"
              },
              "difficulty": 0.2,
              "tags": ["方程"]
            },
            {
              "type": "single_choice",
              "content": {
                "stem": "若|a|=-a，则a的取值范围是（ ）",
                "options": [
                  {"label": "A", "value": "a>0"},
                  {"label": "B", "value": "a<0"},
                  {"label": "C", "value": "a≤0"},
                  {"label": "D", "value": "a≥0"}
                ]
              },
              "answer": {"value": "C"},
              "analysis": {
                "text": "当a≥0时，|a|=a；当a<0时，|a|=-a。由|a|=-a可得-a≥0，即a≤0。",
                "key_point": "分类讨论思想"
              },
              "difficulty": 0.3,
              "tags": ["综合"]
            }
          ]
